PORT=3001
NODE_ENV=development

# ── AI Provider ───────────────────────────────────────────────────────────
# Options: gemini | vertex | dust
API_PROVIDER=gemini

# ── Gemini API (direct) ───────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Vertex AI (Gemini via Google Cloud project) ───────────────────────────
VERTEX_PROJECT_ID=your-google-cloud-project-id
VERTEX_LOCATION=us-central1
# Full service-account JSON (one-line, stringified) — OR use GCLOUD_ACCESS_TOKEN
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Short-lived token from: gcloud auth print-access-token
GCLOUD_ACCESS_TOKEN=

# ── Dust.tt ───────────────────────────────────────────────────────────────
DUST_API_KEY=
DUST_WORKSPACE_ID=
DUST_AGENT_ID=

# ── Queue ─────────────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=3
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=5000
OUTPUT_DIR=./output
MAX_FILE_SIZE_MB=20
LOG_LEVEL=info
LOG_DIR=./logs
IMAGE_QUALITY=90
MAX_DIMENSION=4096
