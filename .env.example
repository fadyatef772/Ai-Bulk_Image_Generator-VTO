PORT=3001
NODE_ENV=development

# ── AI Provider ───────────────────────────────────────────────────────────
# Options: gemini | vertex | dust
API_PROVIDER=gemini

# ── Gemini API (direct) ───────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Vertex AI (Imagen 3 + Virtual Try-On) ─────────────────────────────────
# Auth is via Application Default Credentials (ADC). Run once:
#   gcloud auth application-default login
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VTO_MODEL=virtual-try-on-001
# Full service-account JSON (one-line, stringified) — OR use GCLOUD_ACCESS_TOKEN
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Short-lived token from: gcloud auth print-access-token
GCLOUD_ACCESS_TOKEN=

# ── Dust.tt ───────────────────────────────────────────────────────────────
DUST_API_KEY=
DUST_WORKSPACE_ID=
DUST_AGENT_ID=

# ── Queue / processing ────────────────────────────────────────────────────
QUEUE_BACKEND=memory
QUEUE_CONCURRENCY=3
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=5000
QUEUE_TIMEOUT_MS=120000
OUTPUT_DIR=./output
MAX_FILE_SIZE_MB=20
LOG_LEVEL=info
LOG_DIR=./logs
IMAGE_QUALITY=90
MAX_DIMENSION=4096


# ── Redis (only used when QUEUE_BACKEND=redis) ─────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────
# Production: set to your Vercel frontend URL
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
